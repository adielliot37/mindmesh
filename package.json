{
  "name": "@storacha/agent-knowledge",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-knowledge-server": "dist/mcp/server.js",
    "agent-knowledge-setup": "dist/scripts/setup-domains.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/mcp/server.ts",
    "test": "vitest",
