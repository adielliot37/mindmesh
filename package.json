    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit",
    "setup": "tsx src/scripts/setup-domains.ts",
    "generate-delegations": "tsx src/scripts/generate-delegations.ts",
    "seed": "tsx src/scripts/seed-knowledge.ts"
  },
  "dependencies": {
    "@storacha/client": "latest",
    "@ipld/dag-ucan": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "openai": "^4.0.0",
    "tiktoken": "^1.0.0",
    "zod": "^3.22.0",
    "pino": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  }
}
